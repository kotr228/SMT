<Controls:MetroWindow x:Class="DocControlUI.Windows.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Coffee Cat - Запуск"
        Height="732" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/424.ico"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="{StaticResource PrimaryDarkBrush}"
            BorderThickness="2"
            CornerRadius="15"
            Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок з логотипом -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryDarkBrush}"
                    CornerRadius="13,13,0,0"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Source="/Assets/424.png"
                           Width="64" Height="64"
                           Margin="0,0,20,0"
                           VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Coffee Cat"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}"/>
                        <TextBlock Text="Document Control System v0.10.0"
                                   FontSize="14"
                                   Foreground="{StaticResource BackgroundBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Кнопка закриття -->
                    <Button Grid.Column="2"
                            Content="✕"
                            Width="40" Height="40"
                            FontSize="20"
                            Background="Transparent"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderThickness="0"
                            Click="CloseButton_Click"
                            VerticalAlignment="Top"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="20">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F44336"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Основний контент -->
            <Grid Grid.Row="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Статус перевірки -->
                <GroupBox Grid.Row="0" Header="Статус системи" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Windows Service -->
                        <Border BorderBrush="{StaticResource LightGrayBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="15"
                                Margin="0,0,0,10"
                                Background="{StaticResource WhiteBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="🔧"
                                           FontSize="24"
                                           Margin="0,0,15,0"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Windows Service" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock x:Name="ServiceStatusText"
                                               Text="Перевірка..."
                                               FontSize="12"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           x:Name="ServiceStatusIcon"
                                           Text="⏳"
                                           FontSize="32"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Network Core -->
                        <Border BorderBrush="{StaticResource LightGrayBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="15"
                                Background="{StaticResource WhiteBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="🌐"
                                           FontSize="24"
                                           Margin="0,0,15,0"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Network Core" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock x:Name="NetworkStatusText"
                                               Text="Перевірка..."
                                               FontSize="12"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           x:Name="NetworkStatusIcon"
                                           Text="⏳"
                                           FontSize="32"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Прогрес -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <TextBlock x:Name="StatusMessageText"
                               Text="Ініціалізація системи..."
                               FontSize="12"
                               Foreground="{StaticResource TextBrush}"
                               TextAlignment="Center"
                               Margin="0,0,0,10"/>
                    <ProgressBar x:Name="LoadingProgress"
                                 Height="8"
                                 IsIndeterminate="True"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>

                <!-- Кнопки дій -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                    <!-- Повідомлення про помилку (приховане за замовчуванням) -->
                    <Border x:Name="ErrorPanel"
                            Visibility="Collapsed"
                            Background="#FFEBEE"
                            BorderBrush="#F44336"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="15"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="⚠️ Увага"
                                       FontWeight="Bold"
                                       Foreground="#C62828"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="ErrorMessageText"
                                       TextWrapping="Wrap"
                                       Foreground="#C62828"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <UniformGrid Columns="2" Rows="2">
                        <Button x:Name="StartServiceButton"
                                Content="🚀 Запустити сервіс"
                                Click="StartService_Click"
                                Background="{StaticResource SuccessBrush}"
                                Visibility="Collapsed"
                                ToolTip="Потребує прав адміністратора"/>

                        <Button x:Name="ContinueButton"
                                Content="▶️ Продовжити"
                                Click="Continue_Click"
                                Background="{StaticResource PrimaryBrush}"
                                Visibility="Collapsed"/>

                        <Button x:Name="UIOnlyButton"
                                Content="💻 Тільки UI режим"
                                Click="UIOnly_Click"
                                Background="{StaticResource AccentBrush}"
                                ToolTip="Запустити без Windows Service"/>

                        <Button x:Name="ExitButton"
                                Content="🚪 Вихід"
                                Click="Exit_Click"
                                Background="{StaticResource ErrorBrush}"/>
                    </UniformGrid>
                </StackPanel>
            </Grid>

            <!-- Футер -->
            <Border Grid.Row="2"
                    Background="{StaticResource PrimaryDarkBrush}"
                    CornerRadius="0,0,13,13"
                    Padding="15,10">
                <TextBlock Text="© 2024 Coffee Cat Team | Багатокористувацька система керування документами"
                           FontSize="10"
                           Foreground="{StaticResource BackgroundBrush}"
                           TextAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Controls:MetroWindow>
