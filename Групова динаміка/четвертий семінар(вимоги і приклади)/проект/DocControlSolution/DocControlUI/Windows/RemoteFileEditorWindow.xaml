<mah:MetroWindow x:Class="DocControlUI.Windows.RemoteFileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Редагування віддаленого файлу"
        Width="900" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- File info -->
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock x:Name="FileNameText" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock x:Name="FilePathText" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💾 Зберегти"
                            x:Name="SaveButton"
                            Click="SaveButton_Click"
                            Padding="15,8"
                            Margin="5,0"
                            Background="#0078D7"
                            Foreground="White"/>
                    <Button Content="🔄 Оновити"
                            x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            Padding="15,8"
                            Margin="5,0"/>
                    <Button Content="✖ Закрити"
                            Click="CloseButton_Click"
                            Padding="15,8"
                            Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Text Editor -->
        <Border Grid.Row="1" Padding="10" Background="White">
            <TextBox x:Name="ContentTextBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     TextWrapping="NoWrap"
                     BorderThickness="1"
                     BorderBrush="#CCCCCC"
                     Padding="5"
                     TextChanged="ContentTextBox_TextChanged"/>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="Green" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Готово" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Info -->
                <TextBlock Grid.Column="2" x:Name="InfoText" Text="" VerticalAlignment="Center" Foreground="#666"/>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
